/**
 * 全局错误样板 — 复制为 src/app/error-handler.ts
 */
import { logError } from '@/utils/logger';

export function handleAppError(err: unknown): void {
  logError('app_error', err);
  // 用户可见提示与内部日志分离 — shared/15
}

export function handlePageNotFound(res: { path: string; query?: Record<string, string> }): void {
  logError('page_not_found', res);
  uni.reLaunch({ url: '/pages/not-found/index' });
}
