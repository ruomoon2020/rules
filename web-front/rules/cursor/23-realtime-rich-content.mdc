description: WebSocket、SSE 与富文本安全边界
globs:
  - "src/**/*socket*.ts"
  - "src/**/*websocket*.ts"
  - "src/**/*sse*.ts"
  - "src/**/*editor*.vue"
  - "src/**/*rich*.vue"
  - "src/**/*markdown*.vue"
alwaysApply: false
